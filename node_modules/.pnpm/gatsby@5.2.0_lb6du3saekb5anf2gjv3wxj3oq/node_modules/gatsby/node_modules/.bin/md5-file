#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../md5-file@5.0.0/node_modules/md5-file/cli.js" "$@"
else
  exec node  "$basedir/../../../../../md5-file@5.0.0/node_modules/md5-file/cli.js" "$@"
fi
